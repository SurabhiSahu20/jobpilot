{
  "manifest_version": 3,
  "name": "JobPilot",
  "version": "1.0.0",
  "description": "AI Job Application Tracker. Detects jobs on LinkedIn, Naukri & Wellfound, tracks status, matches resumes, and preps interviews.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.naukri.com/*",
    "*://*.wellfound.com/*",
    "http://localhost:5001/*"
  ],
  "icons": {
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "Open JobPilot",
    "default_icon": {
      "128": "assets/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*",
        "*://*.naukri.com/*",
        "*://*.wellfound.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
