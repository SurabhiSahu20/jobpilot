{
  "manifest_version": 3,
  "name": "JobPilot",
  "version": "1.0.0",
  "description": "AI Job Application Tracker. Detects jobs on LinkedIn, Indeed, Naukri & Wellfound, tracks status, matches resumes, and preps interviews.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "alarms",
    "notifications",
    "sidePanel",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.indeed.com/*",
    "*://*.naukri.com/*",
    "*://*.wellfound.com/*",
    "http://localhost:5001/*",
    "https://jobpilot-backend-cjoz.onrender.com/*",
    "*://*.duckduckgo.com/*",
    "*://*.remotive.com/*"
  ],
  "icons": {
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_icon": {
      "128": "assets/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*",
        "*://*.indeed.com/*",
        "*://*.naukri.com/*",
        "*://*.wellfound.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
